# Django
# DJANGO_SECRET_KEY обязателен, когда DJANGO_DEBUG выключен (production)
DJANGO_SECRET_KEY=your-secret-key-here-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# Database
POSTGRES_DB=apeks
POSTGRES_USER=apeks
POSTGRES_PASSWORD=apeks
POSTGRES_HOST=db
POSTGRES_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Email (console backend for development)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For production, use SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@apeks.space

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# Anthropic API (опционально)
# Если задан, рекомендации /api/me/recommendations обогащаются ИИ (модель claude-fable-5).
# Без ключа используется эвристический алгоритм.
# ANTHROPIC_API_KEY=sk-ant-...

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8000/api
